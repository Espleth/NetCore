{
  "AllowedHosts": "api.example.com",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:80"
      },
      "Https": {
        "Url": "https://0.0.0.0:443",
        "Certificate": {
          "Path": "/app/certs/cert.pem",
          "KeyPath": "/app/certs/privkey.pem"
        }
      }
    }
  },
  "ConnectionStrings": {
    "AppDb": "User ID=postgres;Password=root;Host=127.0.0.1;Port=5432;Database=template_app_db;Pooling=true;",
    "Redis": "localhost:6379",
    "RabbitMq": "amqp://guest:guest@127.0.0.1:5672"
  },
  "EnvironmentConfig": {
    "Environment": "Development",
    "CorsOrigins": ["https://www.example.com", "https://api.example.com", "https://example.com"],
    "ResetPasswordUrl": "https://www.example.com/reset-password"
  },
  "JwtConfig": {
    "ValidIssuer": "ExampleIssuer",
    "ValidAudience": "ExampleAudience",
    "ExpiryInMinutes": "60",
    "SecretKey": "TestSecretKey_A98F126F-17BB-47E7-B1C6-E2BCAFC81BCC",
    "StampSecretKey": "TestStampSecretKey_15D6C20C-E7A0-4DFB-B61A-3616A1191588",
    "CookieDomains": ["example.com", "api.example.com"]
  },
  "LoggingConfig": {
    "LogApiRequests": true,
    "LogRequestHeaders": true,
    "LogRequestBody": true,
    "DetectBots": true,
    "TraceLongRequests": true
  },
  "JobsConfig": {
    "RunJobs": true,
    "LastActivitiesCron": "0 5 * ? * *"
  }
}
